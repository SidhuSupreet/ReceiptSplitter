# --- Frontend (Vite) ---
# These are PUBLIC and baked into the static bundle. Do not put secrets here.

# Google OAuth 2.0 Web Client ID. Create one in Google Cloud Console
# and add your GitHub Pages origin + http://localhost:5173 as Authorized
# JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Cloudflare Worker URL for the OCR endpoint. In local dev this is
# typically http://localhost:8787/ocr (default). In prod, set it to your
# deployed Worker URL, e.g. https://expense-splitter-ocr.<sub>.workers.dev/ocr
VITE_OCR_ENDPOINT=http://localhost:8787/ocr

# Override the public base path used by Vite at build time. Set to
# "/Expense-Splitter/" when deploying to GitHub Pages under that repo name.
# Leave unset for local dev.
# VITE_BASE_PATH=/Expense-Splitter/
